# Copy this file to .env and fill in the values you need.
# Every setting below has a working default defined in supramatch/config.py --
# uncomment a line only if you want to override that default.
#
#   cp .env.example .env

# ==================== DATABASE ====================

# DATABASE_PATH=./data/supramatch.db

# ==================== LOGGING ====================

# LOG_LEVEL=INFO
# LOG_FILE=./logs/supramatch.log

# ==================== CAGE CALCULATIONS ====================

# CAGE_GRID_SPACING=0.5
# CAGE_DISTANCE_THRESHOLD_MULT=2.0
# CAGE_MIN_DISTANCE_THRESHOLD=5.0

# ==================== GUEST CALCULATIONS ====================

# GUEST_RANDOM_SEED=0xf00d
# GUEST_OPTIMIZE_GEOMETRY=true

# ==================== HOST-GUEST MATCHING ====================

# PC_IDEAL_DEFAULT=0.55
# PC_TOLERANCE_DEFAULT=0.09

# ==================== PUBCHEM ====================

# PUBCHEM_REQUEST_DELAY=0.2
# PUBCHEM_CID_BATCH_SIZE=100

# ==================== PRICING (ChemPrice) ====================

# Vendor API keys for `supramatch price lookup`. At least one must be set,
# or price lookups will run but find nothing. Request a key from each
# vendor directly (MolPort, MCule, Chemspace) and paste it here.
MCULE_API_KEY=
MOLPORT_API_KEY=
CHEMSPACE_API_KEY=

# Skip re-querying a guest if it already has a price quote newer than this
# many days.
# PRICE_TTL_DAYS=30

# ==================== FEATURE FLAGS ====================

# ENABLE_CACHE=true

# ==================== DISPLAY ====================

# VOLUME_DECIMALS=2
# PRICE_DECIMALS=2
# PC_DECIMALS=3
